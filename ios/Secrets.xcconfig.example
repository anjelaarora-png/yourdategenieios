// Secrets.xcconfig.example
// Copy this file to Secrets.xcconfig (in the same folder) and fill in your real values.
// Secrets.xcconfig is gitignored — never commit it.

// OpenAI API (for date plan generation)
OPENAI_API_KEY = your_openai_api_key_here

// Google Places + Geocoding (for address autocomplete, place details, and geocoding)
// Get a key at https://console.cloud.google.com/ — enable "Places API" and "Geocoding API"
// If the built app still shows the key as missing, set GOOGLE_PLACES_API_KEY in the Xcode scheme
// (Run → Arguments → Environment Variables) — it overrides Info.plist at runtime.
GOOGLE_PLACES_API_KEY = your_google_places_api_key_here

// Supabase
SUPABASE_URL = https://your-project.supabase.co
SUPABASE_ANON_KEY = your_supabase_anon_key_here
