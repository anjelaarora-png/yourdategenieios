// Secrets.xcconfig.example
// Copy to Secrets.xcconfig (same folder) and fill in real values. Gitignored — never commit.
//
// FULL INTEGRATION MAP: docs/API_KEYS_SETUP.md
//
// IN THIS FILE (iOS client only):
//   GOOGLE_PLACES_API_KEY — autocomplete, place details, geocoding (GooglePlacesService)
//   SUPABASE_URL / SUPABASE_ANON_KEY — auth + database + edge function calls
//
// NOT IN THIS FILE (Supabase Edge Function secrets — see supabase/secrets.example):
//   OPENAI_API_KEY — date plans, gifts, love notes (server-side)
//   LASTFM_API_KEY — playlists only (server-side)
//   GOOGLE_PLACES_API_KEY — also set on Supabase for generate-date-plan venue verification
//
// NO API KEYS NEEDED IN APP:
//   OpenTable / Resy — booking URLs opened in Safari (ReservationWidgetView)
//   Apple login — native ASAuthorization + Supabase Auth Apple provider
//   Google login — NATIVE GoogleSignIn SDK → Supabase signInWithIdToken
//     Needs an iOS OAuth client ID (Google Cloud → Credentials → OAuth client ID → iOS,
//     bundle id com.yourdategenie.app). Add that iOS client ID to the Supabase Google
//     provider's "Authorized Client IDs" too.

// Google Places + Geocoding
// https://console.cloud.google.com/ — enable Places API + Geocoding API
GOOGLE_PLACES_API_KEY = your_google_places_api_key_here

// Native Google Sign-In (iOS OAuth client)
//   GOOGLE_IOS_CLIENT_ID    — looks like 1234567890-abcdef.apps.googleusercontent.com
//   GOOGLE_REVERSED_CLIENT_ID — the same value reversed: com.googleusercontent.apps.1234567890-abcdef
// NOTE: xcconfig treats // as a comment — neither value contains //, so paste as-is.
GOOGLE_IOS_CLIENT_ID = your_ios_client_id.apps.googleusercontent.com
GOOGLE_REVERSED_CLIENT_ID = com.googleusercontent.apps.your_ios_client_id

// Supabase (project jhpwacmsocjmzhimtbxj)
SUPABASE_URL = https://your-project.supabase.co
SUPABASE_ANON_KEY = your_supabase_anon_key_here
