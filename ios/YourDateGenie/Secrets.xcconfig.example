// Secrets.xcconfig.example
// Copy this file to Secrets.xcconfig and fill in your actual API keys.
// NEVER commit Secrets.xcconfig to version control!

// OpenAI API - Get your key from https://platform.openai.com/api-keys
OPENAI_API_KEY = your_openai_api_key_here

// Google Places API - Get your key from https://console.cloud.google.com/
GOOGLE_PLACES_API_KEY = your_google_places_api_key_here

// Supabase - Get these from your Supabase project settings
// Note: Use https:/$()/your-project.supabase.co format to escape the double slash
SUPABASE_URL = https:/$()/your-project-id.supabase.co
SUPABASE_ANON_KEY = your_supabase_anon_key_here
