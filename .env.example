# Supabase (marketing web app)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Google Maps / Places (web address autocomplete only — see docs/API_KEYS_SETUP.md)
VITE_GOOGLE_MAPS_API_KEY=

# Firebase (waitlist — pre-launch only). Project: your-date-genie (number 710263961293)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-date-genie.firebaseapp.com
VITE_FIREBASE_STORAGE_BUCKET=your-date-genie.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=710263961293
VITE_FIREBASE_APP_ID=1:710263961293:web:ad8f4a2cc9b23ef9261b84
VITE_RECAPTCHA_SITE_KEY=

# Launch mode
# Valid values: "prelaunch" (default) | "launched"
# Set to "launched" in Vercel/Netlify production env on 2026-05-27 to swap all CTAs to App Store button.
# Preview environments should be set to "launched" so PR previews show the post-launch UI.
VITE_LAUNCH_MODE=prelaunch

# App Store URL — update when Apple assigns the real ID
VITE_APP_STORE_URL=https://apps.apple.com/app/id0000000000
